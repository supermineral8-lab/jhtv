Options -Indexes
ServerSignature Off

DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS first.
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# v3.1.0: Chinese version is flat at /index-zh.html to avoid directory listings on hosts with weak DirectoryIndex behavior.
RewriteRule ^zh/?$ /index-zh.html [R=301,L,NE]
RewriteRule ^zh/index\.html$ /index-zh.html [R=301,L,NE]

# Canonical single-page routes. Keep old URLs working without splitting SEO signals.
RewriteRule ^about\.html$ /#profile [R=301,L,NE]
RewriteRule ^selected-events\.html$ /#events [R=301,L,NE]
RewriteRule ^contact\.html$ /#contact [R=301,L,NE]
RewriteRule ^about-zh\.html$ /index-zh.html#profile [R=301,L,NE]
RewriteRule ^selected-events-zh\.html$ /index-zh.html#events [R=301,L,NE]
RewriteRule ^contact-zh\.html$ /index-zh.html#contact [R=301,L,NE]
</IfModule>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
Header always set Cross-Origin-Resource-Policy "same-origin"
Header always set Cross-Origin-Opener-Policy "same-origin"
Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self' mailto: https://www.linkedin.com; upgrade-insecure-requests"
</IfModule>

<FilesMatch "^(\.htaccess|\.htpasswd|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|README.*|.*\.config\.(js|ts))$">
  Require all denied
</FilesMatch>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 30 days"
ExpiresByType application/javascript "access plus 30 days"
ExpiresByType image/x-icon "access plus 30 days"
ExpiresByType image/jpeg "access plus 180 days"
ExpiresByType image/png "access plus 180 days"
ExpiresByType image/webp "access plus 180 days"
ExpiresByType image/avif "access plus 180 days"
ExpiresByType image/svg+xml "access plus 180 days"
</IfModule>

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

ErrorDocument 404 /404.html